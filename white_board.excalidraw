      "boundElements": [],
      "updated": 1769186132218,
      "link": null,
      "locked": false,
      "text": "For: \"cat file.txt | grep pattern > output.txt\"\n\nrun_pipeline():\n├── fork() child 1\n│   ├── open(\"file.txt\") → redirect stdin\n│   ├── pipe_fd[1] → redirect stdout\n│   └── execve(\"cat\", ...)\n│\n└── fork() child 2\n    ├── pipe_fd[0] → redirect stdin\n    ├── open(\"output.txt\", O_WRONLY|O_CREAT) → redirect stdout\n    └── execve(\"grep\", ...)\n\nParent waits for both children",
      "fontSize": 16.06657274228878,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For: \"cat file.txt | grep pattern > output.txt\"\n\nrun_pipeline():\n├── fork() child 1\n│   ├── open(\"file.txt\") → redirect stdin\n│   ├── pipe_fd[1] → redirect stdout\n│   └── execve(\"cat\", ...)\n│\n└── fork() child 2\n    ├── pipe_fd[0] → redirect stdin\n    ├── open(\"output.txt\", O_WRONLY|O_CREAT) → redirect stdout\n    └── execve(\"grep\", ...)\n\nParent waits for both children",
      "autoResize": true,
      "lineHeight": 1.25
    },
